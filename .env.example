# Salin file ini menjadi .env dan sesuaikan nilainya per lembaga

# URL base API backend Laravel
VITE_API_BASE_URL=https://cmsunisnuv2.ddev.site/api/v1

# URL backend (digunakan sebagai proxy target saat development)
VITE_BACKEND_URL=https://cmsunisnuv2.ddev.site

# Subdomain lembaga - pilih salah satu:
# www           → UAIKU
# fsh           → Fakultas Syariah dan Hukum
# ftik          → Fakultas Tarbiyah dan Ilmu Keguruan
# fkd           → Fakultas Komunikasi dan Desain
# feb           → Fakultas Ekonomi dan Bisnis
# fst           → Fakultas Sains dan Teknologi
# pascasarjana  → Program Pascasarjana
VITE_SUBDOMAIN=

# API Key lembaga (didapat dari menu Admin → API Keys)
VITE_API_KEY=your-api-key-here

# Jika backend API menggunakan session/cookies (same-origin), set true
VITE_WITH_CREDENTIALS=false
